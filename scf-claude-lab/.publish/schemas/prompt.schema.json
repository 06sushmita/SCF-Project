{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["prompt_id", "version", "status", "prompt"],
  "properties": {
    "prompt_id": { "type": "string" },
    "version": { "type": "integer" },
    "status": {
      "enum": ["DRAFT", "REVIEW", "APPROVED", "ACTIVE", "DEPRECATED", "RETIRED"]
    },
    "prompt": { "type": "object" }
  }
}